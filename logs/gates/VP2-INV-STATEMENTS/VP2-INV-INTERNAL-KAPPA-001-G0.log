fun {A} {E} {C} {S} {A'} {E'} {C'} {S'} {W} {F} {F'} =>
  internal_bisim_kappa : ∀ {A : Type u_1} {E : Type u_2} {C : Type u_3} {S : Type u_4} {A' : Type u_5} {E' : Type u_6}
  {C' : Type u_7} {S' : Type u_8} {W : Type u_9} {F : StaticFrame A E C S W} {F' : StaticFrame A' E' C' S' W}
  (h : KIso F F') (_w : W) (K : Set C),
  image h.hC (K ∩ ERIEC.Closure.Phi F.piRel F.rhoRel K) =
    image h.hC K ∩ ERIEC.Closure.Phi F'.piRel F'.rhoRel (image h.hC K)
