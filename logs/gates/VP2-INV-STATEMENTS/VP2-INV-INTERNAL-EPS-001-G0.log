fun {A} {E} {C} {S} {A'} {E'} {C'} {S'} {W} {F} {F'} =>
  internal_bisim_epsilon : ∀ {A : Type u_1} {E : Type u_2} {C : Type u_3} {S : Type u_4} {A' : Type u_5} {E' : Type u_6}
  {C' : Type u_7} {S' : Type u_8} {W : Type u_9} {F : StaticFrame A E C S W} {F' : StaticFrame A' E' C' S' W}
  (h : KIso F F') (X : Set E),
  image h.hE (X ∩ ERIEC.Hinge.T_prime F.alphaRel F.sigmaRel X) =
    image h.hE X ∩ ERIEC.Hinge.T_prime F'.alphaRel F'.sigmaRel (image h.hE X)
