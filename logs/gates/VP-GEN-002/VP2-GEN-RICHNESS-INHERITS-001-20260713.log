fun {M E C S M' E' C' S'} {parent} {child} =>
  ERIEC.Generation.richness_inherits_generational : ∀ {M E C S M' E' C' S' : Type u_1} {parent : ERIEC.DC M E C S}
  {child : ERIEC.DC M' E' C' S'} (f : ERIEC.Generation.ProliferationMorphism parent child),
  ERIEC.Generation.phi_rich parent ≤ ERIEC.Generation.phi_rich child
ERIEC.Generation.branch_transport_inherits_nu.{u} {M E C S M' E' C' S' : Type u} {parent : ERIEC.DC M E C S}
  {child : ERIEC.DC M' E' C' S'} (f : ERIEC.Generation.ProliferationMorphism parent child) {m : M}
  (hm : m ∈ ERIEC.Hinge.Act parent.rhoRel parent.sigmaRel parent.kappa parent.epsilon parent.s)
  (hbranch : ERIEC.Richness.Branch parent.alphaRel m) :
  ∃ m' ∈ ERIEC.Hinge.Act child.rhoRel child.sigmaRel child.kappa child.epsilon child.s,
    ERIEC.Richness.Branch child.alphaRel m' ∧
      child.alphaRel m' ⊆ ERIEC.Closure.nu (ERIEC.Hinge.T_prime child.alphaRel child.sigmaRel)
'ERIEC.Generation.richness_inherits_generational' depends on axioms: [propext, Classical.choice, Quot.sound]
