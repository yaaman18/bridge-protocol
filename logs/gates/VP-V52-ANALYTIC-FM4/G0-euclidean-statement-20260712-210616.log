ERIEC.Traceability.vocabularyStatus.{u, v} {Text : Type u} {FormulaNF : Type v} [DecidableEq FormulaNF]
  (T : ERIEC.Traceability.VocabularyTest Text FormulaNF) (text : Text) : ERIEC.Traceability.VocabularyStatus
ERIEC.Traceability.vocabularyStatus_complete.{u, v} {Text : Type u} {FormulaNF : Type v} [DecidableEq FormulaNF]
  (T : ERIEC.Traceability.VocabularyTest Text FormulaNF) (text : Text) :
  ERIEC.Traceability.ProofAnchored T text ∨ ERIEC.Traceability.ExceedsTranslation T text
ERIEC.Traceability.vocabularyStatus_sound.{u, v} {Text : Type u} {FormulaNF : Type v} [DecidableEq FormulaNF]
  (T : ERIEC.Traceability.VocabularyTest Text FormulaNF) (text : Text) :
  match ERIEC.Traceability.vocabularyStatus T text with
  | ERIEC.Traceability.VocabularyStatus.proofAnchored => ERIEC.Traceability.ProofAnchored T text
  | ERIEC.Traceability.VocabularyStatus.exceedsTranslation => ERIEC.Traceability.ExceedsTranslation T text
ERIEC.Traceability.vocabularyStatus_cases.{u, v} {Text : Type u} {FormulaNF : Type v} [DecidableEq FormulaNF]
  (T : ERIEC.Traceability.VocabularyTest Text FormulaNF) (text : Text) :
  ERIEC.Traceability.vocabularyStatus T text = ERIEC.Traceability.VocabularyStatus.proofAnchored ∧
      ERIEC.Traceability.ProofAnchored T text ∨
    ERIEC.Traceability.vocabularyStatus T text = ERIEC.Traceability.VocabularyStatus.exceedsTranslation ∧
      ERIEC.Traceability.ExceedsTranslation T text
