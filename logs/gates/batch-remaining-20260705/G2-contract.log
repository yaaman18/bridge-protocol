 {L : EuclideanSpace ℝ (Fin m) →L[ℝ] EuclideanSpace ℝ (Fin m)}\n    {x : EuclideanSpace ℝ (Fin m)}\n    (hx0 : x ≠ 0)\n    (hfix : WorldFixedVector L x) :\n    WldNontrivial L :=\n  ⟨x, hx0, hfix⟩\n\n/-- The loop inner product reduces to the sensitivity inner product. -/\ntheorem worldLoop_inner {m e : Nat}\n    (sigma : EuclideanSpace ℝ (Fin m) → EuclideanSpace ℝ (Fin e))\n    (a : EuclideanSpace ℝ (Fin m))\n    (x y : EuclideanSpace ℝ (Fin m)) :\n    inner ℝ (worldLoop sigma a x) y =\n      inner ℝ (Sens.T_w sigma a x) (Sens.T_w sigma a y) := by\n  simpa [worldLoop, Sens.T_w_adjoint] using\n    ContinuousLinearMap.adjoint_inner_left (Sens.T_w sigma a) y (Sens.T_w sigma a x)\n\n/-- `L = T^* ∘ T` is symmetric with respect to the real inner product. -/\ntheorem worldLoop_symmetric {m e : Nat}\n    (sigma : EuclideanSpace ℝ (Fin m) → EuclideanSpace ℝ (Fin e))\n    (a : EuclideanSpace ℝ (Fin m))\n    (x y : EuclideanSpace ℝ (Fin m)) :\n    inner ℝ (worldLoop sigma a x) y =\n      inner ℝ x (worldLoop sigma a y) := by\n  calc\n    inner ℝ (worldLoop sigma a x) y =\n        inner ℝ (Sens.T_w sigma a x) (Sens.T_w sigma a y) := by\n          exact worldLoop_inner sigma a x y\n    _ = inner ℝ x (worldLoop sigma a y) := by\n          simpa [worldLoop, Sens.T_w_adjoint] using\n            (ContinuousLinearMap.adjoint_inner_right\n              (Sens.T_w sigma a) x (Sens.T_w sigma a y)).symm\n\nend World\n\nend ERIEC\n")

