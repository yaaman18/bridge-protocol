theorem ERIEC.Invariance.INS_invariant.{u_1, u_2, u_3, u_4, u_5, u_6, u_7, u_8, u_9, u_10} : ∀ {A : Type u_1}
  {E : Type u_2} {C : Type u_3} {S : Type u_4} {A' : Type u_5} {E' : Type u_6} {C' : Type u_7} {S' : Type u_8}
  {W : Type u_9} {Ω : Type u_10} {F : ERIEC.Invariance.StaticFrame A E C S W}
  {F' : ERIEC.Invariance.StaticFrame A' E' C' S' W} {step : S → S → Prop} {step' : S' → S' → Prop} {observe : S → Ω}
  {observe' : S' → Ω} (h : ERIEC.Invariance.KIso F F'),
  ERIEC.Invariance.DynamicIso h step step' observe observe' →
    (ERIEC.Dynamics.INS observe (ERIEC.Dynamics.K step {s | F.DCAt s}) ↔
      ERIEC.Dynamics.INS observe' (ERIEC.Dynamics.K step' {s | F'.DCAt s})) :=
fun {A} {E} {C} {S} {A'} {E'} {C'} {S'} {W} {Ω} {F} {F'} {step} {step'} {observe} {observe'} h hdyn =>
  have hV :=
    Set.ext fun s' =>
      Eq.mpr (id (congrFun' (congrArg Iff (ERIEC.Invariance.mem_image._simp_1 h.hS {s | F.DCAt s} s')) (F'.DCAt s')))
        (Eq.mp (congrArg (Iff (F.DCAt (h.hS.symm s'))) (congrArg F'.DCAt (Equiv.apply_symm_apply h.hS s')))
          (ERIEC.Invariance.static_DC_bisim h (h.hS.symm s')));
  have hDown := ERIEC.Invariance.downV_image✝ h.hS hdyn.step_iff {s | F.DCAt s};
  have hK :=
    id
      (Eq.mpr
        (id
          (congrArg (fun _a => _a = (ERIEC.Dynamics.downV step' {s | F'.DCAt s})ᶜ)
            (ERIEC.Invariance.image_compl h.hS (ERIEC.Dynamics.downV step {s | F.DCAt s}))))
        (Eq.mpr (id (congrArg (fun _a => _aᶜ = (ERIEC.Dynamics.downV step' {s | F'.DCAt s})ᶜ) hDown))
          (Eq.mpr
            (id
              (congrArg (fun _a => (ERIEC.Dynamics.downV step' _a)ᶜ = (ERIEC.Dynamics.downV step' {s | F'.DCAt s})ᶜ)
                hV))
            (Eq.refl (ERIEC.Dynamics.downV step' {s | F'.DCAt s})ᶜ))));
  Eq.mpr
    (id
      (congrArg
        (fun _a => ERIEC.Dynamics.INS observe (ERIEC.Dynamics.K step {s | F.DCAt s}) ↔ ERIEC.Dynamics.INS observe' _a)
        (Eq.symm hK)))
    (ERIEC.Invariance.INS_image_iff✝ h.hS observe observe' hdyn.observe_eq (ERIEC.Dynamics.K step {s | F.DCAt s}))
def ERIEC.Invariance.unitaryConjugate : {m n : ℕ} →
  (EuclideanSpace ℝ (Fin m) ≃ₗᵢ[ℝ] EuclideanSpace ℝ (Fin n)) →
    (EuclideanSpace ℝ (Fin m) →L[ℝ] EuclideanSpace ℝ (Fin m)) →
      EuclideanSpace ℝ (Fin n) →L[ℝ] EuclideanSpace ℝ (Fin n) :=
fun {m n} U L => U.toLinearIsometry.toContinuousLinearMap ∘SL L ∘SL U.symm.toLinearIsometry.toContinuousLinearMap
theorem ERIEC.Invariance.unitaryConjugate_apply : ∀ {m n : ℕ}
  (U : EuclideanSpace ℝ (Fin m) ≃ₗᵢ[ℝ] EuclideanSpace ℝ (Fin n))
  (L : EuclideanSpace ℝ (Fin m) →L[ℝ] EuclideanSpace ℝ (Fin m)) (x : EuclideanSpace ℝ (Fin m)),
  (ERIEC.Invariance.unitaryConjugate U L) (U x) = U (L x) :=
fun {m n} U L x =>
  of_eq_true
    (Eq.trans
      (congrFun'
        (congrArg Eq
          (congrArg (⇑U.toLinearIsometry.toContinuousLinearMap)
            (congrArg (⇑L) (LinearIsometryEquiv.symm_apply_apply U x))))
        (U (L x)))
      (eq_self (U (L x))))
theorem ERIEC.Invariance.unitary_conj : ∀ {m n : ℕ} [NeZero m] [NeZero n]
  (U : EuclideanSpace ℝ (Fin m) ≃ₗᵢ[ℝ] EuclideanSpace ℝ (Fin n))
  (L : EuclideanSpace ℝ (Fin m) →L[ℝ] EuclideanSpace ℝ (Fin m)) (eta : ℝ),
  (∀ (lambda : ℝ),
      Module.End.HasEigenvalue (↑L) lambda ↔
        Module.End.HasEigenvalue (↑(ERIEC.Invariance.unitaryConjugate U L)) lambda) ∧
    Submodule.map (↑U.toLinearEquiv) (ERIEC.World.Wld_band L eta) =
        ERIEC.World.Wld_band (ERIEC.Invariance.unitaryConjugate U L) eta ∧
      ERIEC.World.chi (ERIEC.Invariance.unitaryConjugate U L) = ERIEC.World.chi L ∧
        (ERIEC.World.WldNontrivial (ERIEC.Invariance.unitaryConjugate U L) ↔ ERIEC.World.WldNontrivial L) :=
fun {m n} [NeZero m] [NeZero n] U L eta =>
  ⟨ERIEC.Invariance.eigenvalue_unitary✝ U L,
    ⟨ERIEC.Invariance.band_unitary✝ U L eta,
      ⟨of_eq_true
          (Eq.trans
            (congrFun' (congrArg Eq (congrArg abs (congrArg (HSub.hSub 1) (ERIEC.Invariance.lambdaMax_unitary✝ U L))))
              |1 - ERIEC.World.lambdaMax L|)
            (eq_self |1 - ERIEC.World.lambdaMax L|)),
        {
          mp := fun a =>
            Exists.casesOn a fun y h =>
              And.casesOn h fun hy hfix =>
                Exists.intro (U.symm y)
                  ⟨Eq.mpr (id (congrArg Not EmbeddingLike.map_eq_zero_iff._simp_1)) hy,
                    id
                      (LinearIsometryEquiv.injective U
                        (Trans.trans
                          (Trans.trans
                            (Eq.mp
                              (congrArg (Eq (U (L (U.symm y))))
                                (congrArg (⇑(ERIEC.Invariance.unitaryConjugate U L))
                                  (LinearIsometryEquiv.apply_symm_apply U y)))
                              (Eq.symm (ERIEC.Invariance.unitaryConjugate_apply U L (U.symm y))))
                            hfix)
                          (of_eq_true
                            (Eq.trans (congrArg (Eq y) (LinearIsometryEquiv.apply_symm_apply U y)) (eq_self y)))))⟩,
          mpr := fun a =>
            Exists.casesOn a fun x h =>
              And.casesOn h fun hx hfix =>
                Exists.intro (U x)
                  ⟨Eq.mpr (id (congrArg Not EmbeddingLike.map_eq_zero_iff._simp_1)) hx,
                    id
                      (Eq.mpr (id (congrArg (fun _a => _a = U x) (ERIEC.Invariance.unitaryConjugate_apply U L x)))
                        (Eq.mpr (id (congrArg (fun _a => U _a = U x) hfix)) (Eq.refl (U x))))⟩ }⟩⟩⟩
